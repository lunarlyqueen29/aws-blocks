{
  "name": "@aws-blocks/blocks",
  "version": "0.1.1",
  "author": "Amazon Web Services",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "blocks-vendorize": "./dist/vendorize.js"
  },
  "files": [
    "dist",
    "docs",
    "src",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "browser": "./dist/index.browser.js",
      "cdk": "./dist/index.cdk.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cdk": {
      "types": "./dist/index.cdk.d.ts",
      "default": "./dist/index.cdk.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "default": "./dist/client.js"
    },
    "./lambda-handler": "./dist/lambda-handler.js",
    "./scripts": "./dist/scripts.js",
    "./vendorize": "./dist/vendorize.js",
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    },
    "./ui": {
      "types": "./dist/ui.d.ts",
      "default": "./dist/ui.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "default": "./dist/utils.js"
    }
  },
  "scripts": {
    "prebuild": "node ../../scripts/sync-block-docs.mjs",
    "build": "tsc --build",
    "test": "node --test dist/conditional-exports.test.js dist/vendorize-map.test.js"
  },
  "dependencies": {
    "@aws-blocks/core": "^0.1.1",
    "@aws-blocks/auth-common": "^0.1.1",
    "@aws-blocks/bb-auth-basic": "^0.1.1",
    "@aws-blocks/bb-auth-cognito": "^0.1.1",
    "@aws-blocks/bb-auth-oidc": "^0.1.1",
    "@aws-blocks/bb-kv-store": "^0.1.1",
    "@aws-blocks/bb-distributed-table": "^0.1.1",
    "@aws-blocks/bb-realtime": "^0.1.1",
    "@aws-blocks/bb-data": "^0.1.1",
    "@aws-blocks/bb-distributed-data": "^0.1.1",
    "@aws-blocks/bb-async-job": "^0.1.1",
    "@aws-blocks/bb-cron-job": "^0.1.1",
    "@aws-blocks/bb-file-bucket": "^0.1.1",
    "@aws-blocks/bb-app-setting": "^0.1.1",
    "@aws-blocks/bb-knowledge-base": "^0.1.1",
    "@aws-blocks/bb-agent": "^0.1.1",
    "@aws-blocks/bb-tracer": "^0.1.1",
    "@aws-blocks/bb-logger": "^0.1.1",
    "@aws-blocks/bb-email-client": "^0.1.1",
    "@aws-blocks/bb-metrics": "^0.1.1",
    "@aws-blocks/bb-dashboard": "^0.1.1"
  },
  "aws-blocks": {
    "vendorize": {
      "@aws-blocks/bb-kv-store": [
        "KVStore"
      ],
      "@aws-blocks/bb-distributed-table": [
        "DistributedTable"
      ],
      "@aws-blocks/bb-realtime": [
        "Realtime"
      ],
      "@aws-blocks/bb-data": [
        "Database"
      ],
      "@aws-blocks/bb-distributed-data": [
        "DistributedDatabase"
      ],
      "@aws-blocks/bb-async-job": [
        "AsyncJob"
      ],
      "@aws-blocks/bb-cron-job": [
        "CronJob"
      ],
      "@aws-blocks/bb-file-bucket": [
        "FileBucket"
      ],
      "@aws-blocks/bb-app-setting": [
        "AppSetting"
      ],
      "@aws-blocks/bb-knowledge-base": [
        "KnowledgeBase"
      ],
      "@aws-blocks/bb-auth-basic": [
        "AuthBasic"
      ],
      "@aws-blocks/bb-auth-cognito": [
        "AuthCognito"
      ],
      "@aws-blocks/bb-auth-oidc": [
        "AuthOIDC"
      ],
      "@aws-blocks/bb-agent": [
        "Agent"
      ],
      "@aws-blocks/bb-tracer": [
        "Tracer"
      ],
      "@aws-blocks/bb-logger": [
        "Logger"
      ],
      "@aws-blocks/bb-email-client": [
        "EmailClient"
      ],
      "@aws-blocks/bb-metrics": [
        "Metrics"
      ],
      "@aws-blocks/bb-dashboard": [
        "Dashboard"
      ]
    }
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  }
}

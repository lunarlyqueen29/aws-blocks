  "exports": {
    ".": {
      "browser": "./dist/index.browser.js",
      "cdk": {
        "types": "./dist/index.cdk.d.ts",
        "default": "./dist/index.cdk.js"
      },
      "aws-runtime": "./dist/index.aws.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./ui": {
      "types": "./dist/ui.d.ts",
      "default": "./dist/ui.js"
    }
  },
  "scripts": {
    "prebuild": "node ../../scripts/generate-version.mjs AuthCognito",
    "build": "tsc --build",
    "test": "node --test --test-concurrency=1 dist/**/*.test.js",
    "deploy:manual-pools": "node scripts/deploy-manual-test-pools.mjs",
    "teardown:manual-pools": "node scripts/teardown-manual-test-pools.mjs"
  },
  "dependencies": {
    "@aws-blocks/core": "^0.1.1",
    "@aws-blocks/bb-app-setting": "^0.1.1",

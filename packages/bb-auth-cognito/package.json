    "asn1.js": "^5.4.1",
    "bn.js": "^5.2.3",
    "esbuild": "^0.25.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "aws-cdk-lib": "^2.257.0",
    "constructs": "^10.6.0"
